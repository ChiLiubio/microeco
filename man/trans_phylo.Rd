\describe{
\item{\code{layout}}{tree layout: "fan", "circular", "radial", or "rectangular", default "fan"}

\item{\code{open_angle}}{numeric, opening angle of the fan (0-360), default 30 (fan/circular only)}

\item{\code{branch_size}}{branch line width, default 0.3}

\item{\code{tip_point}}{logical, whether to show tip points, default TRUE}

\item{\code{tip_point_size}}{tip point size, default 2}

