\item{\code{tip_point_stroke}}{tip point border width, default 0.3}

\item{\code{tip_point_alpha}}{tip point transparency, default 0.9}

\item{\code{show_tip_label}}{logical, whether to show tip labels, default FALSE}

\item{\code{tip_label_size}}{tip label font size, default 2}

\item{\code{tip_label_offset}}{tip label offset, default 0.5}

\item{\code{show_node_label}}{logical, whether to show internal node labels, default FALSE}

\item{\code{branch_color_by_group}}{logical, color branches by group, default TRUE}

\item{\code{branch_color}}{unified branch color (when branch_color_by_group = FALSE), default "grey40"}

\item{\code{legend_title}}{legend title, default uses group_col}

\item{\code{legend_position}}{legend position, default "right"}

\item{\code{legend_font_size}}{legend font size, default 3.5}

