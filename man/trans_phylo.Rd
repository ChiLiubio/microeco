\subsection{Method \code{add_ring()}}{
Add one outer ring annotation layer to the current plot.
  Extra arguments (...) are passed to ggtreeExtra::geom_fruit() for advanced customization
  (e.g. axis.params, grid.params, direction).
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{trans_phylo$add_ring(
  col_name,
  ring_data = NULL,
  color_low = "#0D0887",
  color_high = "#F0F921",
  limits = NULL,
  categorical_colors = NULL,
  ring_width = NULL,
  ring_offset = NULL,
  ring_gap = 0.03,
  ring_offset_first = 0.02,
  ring_width_bar = 0.03,
  ring_width_other = 0.03,
  show_legend = TRUE,
  legend_title_custom = NULL,
  ring_label = NULL,
  geom = "bar",
  na_fill = "grey90",
  na_replace = "Unknown",
  point_size = 1.5,
  ...
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{col_name}}{string, column name from ring_data to display}

\item{\code{ring_data}}{optional custom data.frame for this ring (overrides self$ring_data)}

\item{\code{color_low}}{color for low numeric values, default "#0D0887"}

\item{\code{color_high}}{color for high numeric values, default "#F0F921"}

\item{\code{limits}}{numeric vector of length 2, explicit limits for the fill scale;
default NULL means auto from data range}

\item{\code{categorical_colors}}{color vector for categorical columns, default NULL (auto)}

\item{\code{ring_width}}{ring width, default NULL; see ring_width_bar and ring_width_other.}

\item{\code{ring_offset}}{ring offset, default NULL; If NULL, ring_offset_first + ring_gap}

\item{\code{ring_gap}}{numeric, gap between consecutive rings when ring_offset is not manually specified}

\item{\code{ring_offset_first}}{numeric, starting offset for the very first ring when ring_offset is not manually specified}

\item{\code{ring_width_bar}}{numeric, default ring width for numeric bar-type rings when ring_width is NULL}

\item{\code{ring_width_other}}{numeric, default ring width for non-bar rings (categorical color band, point, star) when ring_width is NULL}

\item{\code{show_legend}}{logical, whether to show this ring's legend, default TRUE}

\item{\code{legend_title_custom}}{custom legend title, default uses column name}

\item{\code{ring_label}}{label around the ring, default uses column name}

\item{\code{geom}}{type: "bar" for bar heatmap, "point" for scatter, "star" for stars;
categorical columns automatically use color band regardless of this setting}

\item{\code{na_fill}}{fill color for NA values, default "grey90"}

\item{\code{na_replace}}{categorical value to replace NA/empty with, default "Unknown".
Only applied when categorical_colors is NULL (auto palette). Set to NULL to keep
NA values as NA, in which case they are colored with na_fill via
scale_fill_manual(na.value = na_fill). When categorical_colors is provided,
NA is always kept as NA and colored with na_fill (regardless of na_replace),
so the user's color vector does not need to cover an extra "Unknown" level.}

\item{\code{point_size}}{point size (only for geom = "point"), default 1.5}

\item{\code{...}}{additional arguments passed to ggtreeExtra::geom_fruit() (e.g. axis.params, grid.params)}
}
